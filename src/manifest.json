{
  "manifest_version": 3,
  "name": "Seeking the Perfect Key",
  "version": "0.1.0",
  "description": "Encrypted local vault + generator + HIBP leak check",
  "action": {
    "default_title": "Vault",
    "default_popup": "popup/index.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background/sw.js",
    "type": "module"
  },
  "permissions": ["storage"],
  "host_permissions": ["https://api.pwnedpasswords.com/*"],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'; base-uri 'none';"
  }
}