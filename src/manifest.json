{
  "manifest_version": 3,
  "name": "Vault Extension",
  "version": "0.1.0",
  "action": {
    "default_popup": "src/popup/index.html"
  },
  "background": {
    "service_worker": "src/background/sw.js",
    "type": "module"
  },
  "permissions": ["storage"],
  "icons": {
    "16": "public/icons/icon16.png",
    "48": "public/icons/icon48.png",
    "128": "public/icons/icon128.png"
  }
}
