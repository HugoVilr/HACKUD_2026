{
  "manifest_version": 3,
  "name": "Vault Extension",
  "version": "0.1.0",
  "action": {
    "default_popup": "src/popup/popup.html"
  },
  "background": {
    "service_worker": "src/background/sw.js",
    "type": "module"
  },
  "permissions": ["storage"],
  "host_permissions": ["https://api.pwnedpasswords.com/*"]
}
